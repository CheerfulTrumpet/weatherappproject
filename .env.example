# Cognitive Weather Oracle - Environment Configuration
# 
# Copy this file to .env and replace with your actual values
# DO NOT commit .env to version control (add to .gitignore)

# OpenWeatherMap API Key (get free key at https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_api_key_here

# Optional: Override default location
# DEFAULT_LOCATION=New York, NY

# Optional: Override default units
# DEFAULT_UNITS=metric  # metric for Celsius, imperial for Fahrenheit

# Optional: Override log level
# LOG_LEVEL=DEBUG  # INFO, DEBUG, WARNING, ERROR, CRITICAL
